<?xml version="1.0" encoding="utf-8"?>
<com.sothree.slidinguppanel.SlidingUpPanelLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/tools"
    xmlns:sothree="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sliding_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="bottom"
    sothree:umanoInitialState="anchored"
    sothree:umanoAnchorPoint="0.5"
    sothree:umanoPanelHeight="36dp"
    sothree:umanoShadowHeight="0dp"
    sothree:umanoFadeColor="@android:color/transparent"
    sothree:umanoDragView="@+id/dragView"
    sothree:umanoScrollableView="@+id/recycler">

    <!-- MAIN CONTENT -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical">
    </FrameLayout>

    <LinearLayout
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/background_autofill_sheet"
        android:clipToPadding="true"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:orientation="vertical"
        android:tag="layout/bottom_sheet_autofill_select_item_0">

        <LinearLayout
            android:id="@+id/dragView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:layout_width="64.0dip"
                android:layout_height="4.0dip"
                android:layout_gravity="center"
                android:layout_marginTop="16.0dip"
                android:layout_marginBottom="8.0dip"
                android:background="@drawable/background_search_bar" />

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="42.0dip"
                android:layout_marginTop="8.0dip"
                android:layout_marginStart="12dip"
                android:layout_marginEnd="12dip"
                android:layout_marginBottom="16.0dip"
                android:background="@drawable/background_search_bar"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/searchIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:layout_marginStart="8.0dip"
                    android:clickable="false"
                    android:padding="8.0dip"
                    android:src="@drawable/ic_toolbar_search"
                    android:transitionName="@string/vaultListTransitionSearchIcon"
                    app:tint="@color/grey" />

                <EditText
                    android:id="@+id/search"
                    android:layout_width="0.0dip"
                    android:layout_height="fill_parent"
                    android:layout_weight="1.0"
                    android:background="@android:color/transparent"
                    android:hint="@string/hintSearchAll"
                    android:imeOptions="actionDone"
                    android:inputType="text"
                    android:paddingStart="8.0dip"
                    android:paddingEnd="0.0dip"
                    android:textColor="@color/grey"
                    android:textColorHint="@color/grey"
                    android:textSize="16.0sp" />

                <ImageButton
                    android:id="@+id/clear"
                    android:layout_width="wrap_content"
                    android:layout_height="fill_parent"
                    android:layout_gravity="end"
                    android:background="?android:selectableItemBackgroundBorderless"
                    android:paddingStart="16.0dip"
                    android:paddingEnd="16.0dip"
                    android:src="@drawable/ic_toolbar_close"
                    android:tag="binding_1" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:id="@+id/toolbarDivider"
            style="@style/Theme.eSecrets.Divider"
            android:visibility="visible" />

        <FrameLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
<!--            android:layout_marginTop="8.0dip">-->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler"
                style="@style/Theme.eSecrets.Autofill.List"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:minHeight="@dimen/autoFillRecyclerHeightConstraint"
                android:paddingBottom="@dimen/itemsListBottomPadding" />

<!--
            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:tag="binding_2">

                <TextView
                    android:id="@+id/emptyViewTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="24.0dip"
                    android:layout_marginLeft="24.0dip"
                    android:layout_marginTop="32.0dip"
                    android:layout_marginRight="24.0dip"
                    android:gravity="center"
                    android:text="@string/categoryListLabelNoResults"
                    android:textAppearance="@style/Theme.eSecrets.Text.Body.Medium"
                    android:textSize="16.0sp" />

                <TextView
                    android:id="@+id/emptyViewMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="24.0dip"
                    android:layout_marginLeft="24.0dip"
                    android:layout_marginTop="8.0dip"
                    android:layout_marginRight="24.0dip"
                    android:gravity="center"
                    android:text="@string/categoryListLabelNoResultsMessage"
                    android:textAppearance="@style/Theme.eSecrets.Text.Body.Secondary" />
            </LinearLayout>
-->
        </FrameLayout>
    </LinearLayout>
</com.sothree.slidinguppanel.SlidingUpPanelLayout>
