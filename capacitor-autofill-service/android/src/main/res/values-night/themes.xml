<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.eSecrets" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimaryDark</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDarkTint</item>
        <item name="colorOnPrimary">@color/colorPrimaryDarkContrast</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorSecondaryDark</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryDarkTint</item>
        <item name="colorOnSecondary">@color/colorSecondaryDarkContrast</item>

        <item name="colorSurface">@color/colorStep100Dark</item>

        <item name="android:colorBackground">@color/colorSecondary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/colorSecondary</item>
        <!-- Customize your theme here. -->
        <item name="android:background">@color/colorSecondary</item>
<!--        <item name="android:toolbarStyle">@color/colorSecondary</item>-->
    </style>

    <style name="Theme.eSecrets.Divider" parent="@style/Theme.eSecrets">
        <item name="android:background">@color/colorBorderDark</item>
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">1sp</item>
    </style>

    <style name="Theme.eSecrets.Autofill.List" parent="@style/Theme.eSecrets">
        <item name="android:background">@color/colorBorderDark</item>
    </style>
    <style name="Theme.eSecrets.Autofill.List.Item" parent="@style/Theme.eSecrets">
        <item name="android:background">@color/colorItemBackgroundDark</item>
        <item name="android:layout_marginBottom">1sp</item>
    </style>
    <style name="Theme.eSecrets.Autofill.List.Item.Title" parent="@style/Theme.eSecrets.Autofill.List.Item">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/light_grey</item>
    </style>
    <style name="Theme.eSecrets.Autofill.List.Item.Subtitle" parent="@style/Theme.eSecrets.Autofill.List.Item">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/greyDark</item>
    </style>
</resources>