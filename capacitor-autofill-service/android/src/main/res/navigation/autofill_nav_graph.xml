<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/autofill_nav_graph"
    app:startDestination="@id/authFragment">

    <fragment
        android:id="@+id/authFragment"
        android:name="io.esecrets.capacitor.autofill.ui.AuthFragment"
        android:label="AuthFragment"
        tools:layout="@layout/fragment_auth" >
        <action
            android:id="@+id/action_authFragment_to_secretListFragment"
            app:destination="@id/secretListFragment" />
    </fragment>
    <fragment
        android:id="@+id/secretListFragment"
        android:name="io.esecrets.capacitor.autofill.ui.SecretListFragment"
        android:label="SecretListFragment"
        tools:layout="@layout/fragment_secret_list" >
        <argument
            android:name="password"
            app:argType="string" />
    </fragment>
</navigation>