{
  "name": "capacitor-android-webintent",
  "version": "0.0.1",
  "description": "Capacitor plugin for Android launch intent extras and ACTION_VIEW (replaces Cordova WebIntent)",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/"
  ],
  "author": "Higor Wuttke Nunes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/higorn/capacitor-android-webintent.git"
  },
  "keywords": ["capacitor", "plugin", "android", "intent"],
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.js",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "rimraf": "^5.0.5",
    "rollup": "^4.9.0",
    "typescript": "~5.4.0"
  },
  "peerDependencies": {
    "@capacitor/core": ">=8.0.0"
  },
  "capacitor": {
    "android": {
      "src": "android"
    }
  }
}
