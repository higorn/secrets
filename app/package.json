{
  "name": "secrets",
  "version": "0.0.1",
  "author": "Higor Wuttke Nunes",
  "homepage": "https://e-secrets.web.app/",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host=0.0.0.0 --port=8100",
    "start-pwa": "http-server -p 8080 -S -c-1 www/",
    "start-android": "ionic cap run android --livereload --external",
    "build": "ng build",
    "build-prod": "ng build --configuration production",
    "deploy": "firebase deploy",
    "release-android": "ionic capacitor build android --configuration production --release",
    "resources-android": "cordova-res android --skip-config --copy",
    "test": "jest --config jest.config.cjs --watch --detectOpenHandles",
    "test:ci": "jest --config jest.config.cjs --watchAll=false --detectOpenHandles",
    "lint": "ng lint",
    "e2e": "playwright test"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/platform-browser-dynamic": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@angular/service-worker": "^20.3.0",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@ionic/angular": "^8.8.1",
    "@ionic/storage-angular": "^4.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@types/node-forge": "^1.3.11",
    "capacitor-android-webintent": "file:../capacitor-android-webintent",
    "capacitor-autofill-service": "file:../capacitor-autofill-service",
    "capacitor-googleauth-plugin": "file:../capacitor-googleauth-plugin",
    "capacitor-native-biometric": "^4.2.2",
    "ngx-clipboard": "^16.0.0",
    "node-forge": "^1.3.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.0",
    "uuid": "^9.0.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.9",
    "@angular/cli": "^20.3.9",
    "@angular/compiler": "^20.3.0",
    "@angular/compiler-cli": "^20.3.0",
    "@angular/language-service": "^20.3.0",
    "@capacitor/cli": "^8.2.0",
    "@ionic/angular-toolkit": "^12.3.0",
    "@playwright/test": "^1.49.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@eslint/js": "^9.15.0",
    "angular-eslint": "^20.7.0",
    "eslint": "^9.15.0",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.6.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.15.0"
  },
  "description": "e-Secrets secrets manager"
}
